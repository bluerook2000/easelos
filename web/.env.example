# NextAuth.js (required)
NEXTAUTH_SECRET=generate-a-random-secret-here
# Use http://localhost:3000 for local dev, https://easelos.com for production
NEXTAUTH_URL=http://localhost:3000

# Email (optional — omit for console transport)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@easelos.com

# Admin access (comma-separated emails)
# ADMIN_EMAILS=admin@easelos.com

# Deployment: Next.js server runs via launchd (com.easelos.nextjs.plist)
# Caddy reverse-proxies from :8099 to :3000
# Cloudflare Tunnel routes easelos.com to :8099
# Production secrets go in .env.local (auto-read by Next.js, git-ignored)
